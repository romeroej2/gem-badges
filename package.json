{
  "name": "fancy-buttons",
  "version": "0.1.0",
  "description": "Beautiful precious stone-inspired React button components",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "showcase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "showcase:dev": "cd showcase && bun run dev",
    "showcase:build": "cd showcase && bun run build",
    "showcase:start": "cd showcase && bun run start"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^5",
    "vite-plugin-dts": "^3"
  }
}
